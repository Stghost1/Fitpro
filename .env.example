# ─────────────────────────────────────────────────────────────────────────────
# FitPro Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
# Use sk_test_... for testing, sk_live_... for production.
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_KEY

# Create a recurring Price in Stripe dashboard → Products → Add Product
# Copy the Price ID (starts with price_...)
STRIPE_PRICE_ID=price_REPLACE_WITH_YOUR_PRICE_ID

# ── App URL ───────────────────────────────────────────────────────────────────
# Your Vercel deployment URL (no trailing slash)
# During local dev, leave as http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
